# ============================================================
# Universal Communication Platform (UCP) - .gitignore
# ============================================================

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
Thumbs.db

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (NEVER commit secrets)
.env
.env.local
.env.*.local
.env.production
.env.development

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
local-*
.claude
.z-ai-config
*.log
dev.log
dev.out.log
server.log
process.log

# Skills directory
/skills/

# Database (SQLite dev)
*.db
*.db-journal
*.db-wal
*.db-shm
/db/*.db
/db/*.db-journal
/db/*.db-wal
/db/*.db-shm

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Build artifacts
dist/
build/
*.tsbuildinfo

# Logs directory
/logs/

# Download directory (user-facing deliverables, not part of source)
/download/
