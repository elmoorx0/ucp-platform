# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL="file:./db/custom.db"
# For production: DATABASE_URL="postgresql://user:pass@localhost:5432/ucp"

# JWT Secret (used for dashboard authentication) — minimum 32 characters
JWT_SECRET="change-me-to-a-secure-secret-min-32-chars-long"

# API Key Hashing Secret — used to hash API keys before storing
API_KEY_HASH_SECRET="change-me-to-another-secure-secret"

# Internal API Token — used for Next.js ↔ Realtime Gateway communication
INTERNAL_API_TOKEN="change-me-to-a-secure-internal-token"

# Realtime Gateway URL (default: localhost:3003)
REALTIME_GATEWAY_URL="http://localhost:3003"

# Redis URL (optional, for multi-instance production)
# REDIS_URL="redis://localhost:6379"
