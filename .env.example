# ============================================================
# Universal Communication Platform (UCP) - Environment Variables
# ============================================================
# Copy this file to .env for local development,
# or set these variables in your Vercel/Railway dashboard for production.
# ============================================================

# ---------- DATABASE ----------
# UCP uses SQLite everywhere — locally as a file, in production as Turso (libSQL).
# Turso is "SQLite in the cloud" — serverless-friendly, free, edge-ready.
#
# Local development (default — file-based SQLite):
DATABASE_URL="file:./db/custom.db"
#
# Production on Vercel/Railway (Turso — free SQLite database):
#   1. Sign up at https://turso.tech (free)
#   2. Create a database:  turso db create ucp
#   3. Get the URL:        turso db show ucp --url
#   4. Get the token:      turso db tokens create ucp
#   5. Set DATABASE_URL="libsql://ucp-<your-name>.turso.io?authToken=<your-token>"
#
# DATABASE_URL="libsql://ucp-your-name.turso.io?authToken=your-auth-token-here"

# ---------- SECURITY ----------
# JWT Secret for dashboard authentication (min 32 chars)
# Generate one: openssl rand -base64 48
JWT_SECRET="change-me-to-a-secure-jwt-secret-min-32-chars-long-please"

# Secret used to hash API keys before storing in DB
# Generate one: openssl rand -base64 32
API_KEY_HASH_SECRET="change-me-to-another-secure-secret"

# Internal token for Next.js ↔ Realtime Gateway communication
# Generate one: openssl rand -base64 32
INTERNAL_API_TOKEN="change-me-to-a-secure-internal-token"

# ---------- REALTIME GATEWAY ----------
# URL of the Realtime Gateway (must be a separate deployment — Railway/Render/Fly.io)
# For local dev: http://localhost:3003
# For production: https://your-gateway-url.up.railway.app
REALTIME_GATEWAY_URL="http://localhost:3003"

# ---------- NODE ENV ----------
NODE_ENV="development"
# Set to "production" in Vercel (automatic)
