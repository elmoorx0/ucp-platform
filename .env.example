# ============================================================
# Universal Communication Platform (UCP) - Environment Variables
# ============================================================
# Copy this file to .env for local development,
# or set these variables in your Vercel dashboard for production.
# ============================================================

# ---------- DATABASE ----------
# Local SQLite (development only — does NOT work on Vercel)
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./db/custom.db"

# Production PostgreSQL (REQUIRED for Vercel)
# Option 1: Neon (recommended, serverless Postgres) — https://neon.tech
# Option 2: Vercel Postgres — https://vercel.com/docs/storage/vercel-postgres
# Option 3: Supabase — https://supabase.com
# Option 4: Railway — https://railway.app
#
# DATABASE_PROVIDER="postgresql"
# DATABASE_URL="postgresql://user:password@host:5432/ucp?sslmode=require&pgbouncer=true&connect_timeout=15"

# ---------- SECURITY ----------
# JWT Secret for dashboard authentication (min 32 chars)
# Generate one: openssl rand -base64 48
JWT_SECRET="change-me-to-a-secure-jwt-secret-min-32-chars-long-please"

# Secret used to hash API keys before storing in DB
# Generate one: openssl rand -base64 32
API_KEY_HASH_SECRET="change-me-to-another-secure-secret"

# Internal token for Next.js ↔ Realtime Gateway communication
# Generate one: openssl rand -base64 32
INTERNAL_API_TOKEN="change-me-to-a-secure-internal-token"

# ---------- REALTIME GATEWAY ----------
# URL of the Realtime Gateway (must be a separate deployment — Railway/Render/Fly.io)
# For local dev: http://localhost:3003
# For production: https://your-gateway-url.up.railway.app
REALTIME_GATEWAY_URL="http://localhost:3003"

# Public URL of the Gateway (used by browser clients for Socket.io connection)
# Leave empty to use the same as REALTIME_GATEWAY_URL
# REALTIME_GATEWAY_PUBLIC_URL="https://your-gateway-url.up.railway.app"

# ---------- REDIS (Optional — for multi-instance Gateway deployments) ----------
# When deploying multiple Gateway instances, use Redis for Socket.io adapter
# REDIS_URL="redis://default:password@redis-host:6379"

# ---------- NEXTAUTH (Optional — if using NextAuth instead of custom JWT) ----------
# NEXTAUTH_SECRET="another-secure-secret"
# NEXTAUTH_URL="https://your-app.vercel.app"

# ---------- NODE ENV ----------
NODE_ENV="development"
# Set to "production" in Vercel (automatic)
