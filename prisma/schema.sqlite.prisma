// ============================================================
// UCP Prisma Schema — SQLite variant (LOCAL DEVELOPMENT ONLY)
// ============================================================
// This is the SQLite-compatible schema for local development.
// Production uses prisma/schema.prisma (PostgreSQL).
//
// To switch to SQLite locally:
//   bun run db:use-sqlite
//
// To switch back to PostgreSQL:
//   bun run db:use-postgres
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// The model definitions below are IDENTICAL to schema.prisma (PostgreSQL).
// They're inlined here because Prisma doesn't support `env()` for the
// provider field. When you add a new model, update BOTH files.

model Tenant {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  status      String    @default("active")
  plan        String    @default("free")
  metadata    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  users       User[]
  projects    Project[]
  auditLogs   AuditLog[]
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String?
  passwordHash    String
  role            String    @default("viewer")
  status          String    @default("active")
  lastLoginAt     DateTime?
  avatarUrl       String?
  tenantId        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  auditLogs       AuditLog[]
  @@index([tenantId])
  @@index([role])
}

model Project {
  id              String    @id @default(cuid())
  tenantId        String
  name            String
  slug            String
  description     String?
  status          String    @default("active")
  iconUrl         String?
  webhookUrl      String?
  metadata        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  apiKeys         ApiKey[]
  endUsers        EndUser[]
  devices         Device[]
  notifications   Notification[]
  providers       ProviderConfig[]
  events          Event[]
  realtimeChannels RealtimeChannel[]
  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([status])
}

model ApiKey {
  id              String    @id @default(cuid())
  projectId       String
  name            String
  keyPrefix       String
  hashedKey       String    @unique
  scopes          String    @default("[]")
  permissions     String    @default("[]")
  rateLimitPerMin Int       @default(1000)
  lastUsedAt      DateTime?
  lastUsedIp      String?
  expiresAt       DateTime?
  status          String    @default("active")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  auditLogs       AuditLog[]
  @@index([projectId])
  @@index([hashedKey])
  @@index([status])
}

model EndUser {
  id              String    @id @default(cuid())
  projectId       String
  externalId      String
  email           String?
  phone           String?
  name            String?
  avatarUrl       String?
  language        String    @default("en")
  timezone        String    @default("UTC")
  tags            String    @default("[]")
  attributes      String    @default("{}")
  status          String    @default("active")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  devices         Device[]
  notifications   NotificationTarget[]
  @@unique([projectId, externalId])
  @@index([projectId, externalId])
  @@index([email])
}

model Device {
  id              String    @id @default(cuid())
  projectId       String
  endUserId       String
  token           String    @unique
  platform        String
  userAgent       String?
  appVersion      String?
  pushSubscription String?
  status          String    @default("active")
  lastSeenAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  endUser         EndUser   @relation(fields: [endUserId], references: [id], onDelete: Cascade)
  notificationTargets NotificationTarget[]
  @@index([projectId, endUserId])
  @@index([projectId, status])
}

model Notification {
  id              String    @id @default(cuid())
  projectId       String
  channel         String
  title           String
  body            String
  imageUrl        String?
  data            String    @default("{}")
  targetingType   String    @default("user")
  targetingData   String    @default("{}")
  providerName    String?
  status          String    @default("pending")
  priority        String    @default("normal")
  scheduledAt     DateTime?
  sentAt          DateTime?
  totalTargets    Int       @default(0)
  deliveredCount  Int       @default(0)
  failedCount     Int       @default(0)
  pendingCount    Int       @default(0)
  externalId      String?
  metadata        String    @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  targets         NotificationTarget[]
  @@index([projectId, status])
  @@index([projectId, channel])
  @@index([projectId, createdAt])
  @@index([scheduledAt])
}

model NotificationTarget {
  id              String    @id @default(cuid())
  notificationId  String
  endUserId       String?
  deviceId        String?
  channel         String
  providerName    String?
  status          String    @default("pending")
  providerMessageId String?
  attempts        Int       @default(0)
  lastError       String?
  deliveredAt     DateTime?
  readAt          DateTime?
  clickedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  notification    Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  endUser         EndUser?  @relation(fields: [endUserId], references: [id], onDelete: SetNull)
  device          Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  @@index([notificationId])
  @@index([endUserId])
  @@index([deviceId])
  @@index([status])
}

model ProviderConfig {
  id              String    @id @default(cuid())
  projectId       String
  name            String
  displayName     String?
  credentials     String
  config          String    @default("{}")
  isDefault       Boolean   @default(false)
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@unique([projectId, name])
  @@index([projectId, enabled])
}

model Event {
  id              String    @id @default(cuid())
  projectId       String
  type            String
  source          String
  payload         String    @default("{}")
  channel         String?
  delivered       Boolean   @default(false)
  deliveredAt     DateTime?
  subscriberCount Int       @default(0)
  createdAt       DateTime  @default(now())
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@index([projectId, type])
  @@index([projectId, createdAt])
  @@index([channel, delivered])
}

model RealtimeChannel {
  id              String    @id @default(cuid())
  projectId       String
  name            String
  type            String    @default("public")
  metadata        String    @default("{}")
  subscriberCount Int       @default(0)
  lastActivityAt  DateTime?
  createdAt       DateTime  @default(now())
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@unique([projectId, name])
  @@index([projectId, type])
}

model AuditLog {
  id              String    @id @default(cuid())
  tenantId        String?
  userId          String?
  apiKeyId        String?
  action          String
  resource        String?
  resourceId      String?
  before          String?
  after           String?
  ip              String?
  userAgent       String?
  status          String    @default("success")
  message         String?
  createdAt       DateTime  @default(now())
  tenant          Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  apiKey          ApiKey?   @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  @@index([tenantId, createdAt])
  @@index([userId])
  @@index([action])
}

model DailyStat {
  id              String    @id @default(cuid())
  projectId       String
  date            DateTime
  channel         String
  sent            Int       @default(0)
  delivered       Int       @default(0)
  failed          Int       @default(0)
  read            Int       @default(0)
  clicked         Int       @default(0)
  messagesSent    Int       @default(0)
  activeConnections Int     @default(0)
  peakConnections Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@unique([projectId, date, channel])
  @@index([projectId, date])
}
